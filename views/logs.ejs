<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server Überwachung | Big Brother</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { 
            /* Ein eiskaltes Neon-Cyan für den "Big Brother" Hacker Look */
            --accent: #00f0ff; 
            --accent-dark: #008b99;
            --bg-card: rgba(10, 10, 15, 0.85);
        }

        body {
            background-image: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)), url('/images/background.jpg');
            background-attachment: fixed;
            background-position: center;
            background-size: cover;
            background-repeat: no-repeat;
            color: white;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
            font-family: 'Segoe UI', Roboto, sans-serif;
        }

        /* --- GLASSMORPHISM CARD --- */
        .glass-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(10, 10, 15, 0.9) 100%) !important;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 240, 255, 0.15) !important;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6), inset 0 0 20px rgba(0, 240, 255, 0.05);
        }

        /* --- LAYOUT & SCROLLING --- */
        .log-container { max-width: 1400px; margin: 40px auto; padding: 0 20px; }
        
        .scroll-container {
            max-height: 65vh; 
            overflow-y: auto;
            scrollbar-width: none; 
            -ms-overflow-style: none; 
            border-radius: 0 0 20px 20px;
        }
        .scroll-container::-webkit-scrollbar { display: none; }

        /* --- TABELLE --- */
        .table { --bs-table-bg: transparent; color: white !important; margin-bottom: 0; }
        .table thead th { 
            position: sticky; top: 0; z-index: 10;
            background: rgba(10, 10, 15, 0.95);
            color: var(--accent) !important; 
            text-transform: uppercase; 
            font-size: 0.8rem; 
            letter-spacing: 2px; 
            border-bottom: 1px solid var(--accent);
            padding: 20px 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }
        .table tbody td { border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; padding: 15px; }
        .table-hover tbody tr:hover { background: rgba(0, 240, 255, 0.05) !important; transition: background 0.2s ease; }

        /* --- BADGES FÜR EVENTS --- */
        .badge-action { 
            font-size: 0.7rem; padding: 6px 12px; border-radius: 30px; font-weight: bold; 
            text-transform: uppercase; letter-spacing: 1px; display: inline-block; min-width: 120px; text-align: center; 
        }
        .bg-msg { background-color: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid #3b82f6; } 
        .bg-voice { background-color: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid #10b981; } 
        .bg-stream { background-color: rgba(251, 191, 36, 0.2); color: #fcd34d; border: 1px solid #fbbf24; } 
        .bg-user { background-color: rgba(168, 85, 247, 0.2); color: #c084fc; border: 1px solid #a855f7; } 
        .bg-mod { background-color: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid #ef4444; } 
        .bg-sys { background-color: rgba(100, 116, 139, 0.2); color: #94a3b8; border: 1px solid #64748b; } 

        /* --- TYPOGRAFIE & DETAILS --- */
        .username-bright { color: #ffffff !important; font-weight: 700; font-size: 1rem; text-shadow: 0 0 10px rgba(255,255,255,0.3); }
        .time-text { font-size: 0.9rem; font-weight: bold; color: #ffffff; white-space: nowrap; font-family: 'Consolas', monospace; text-shadow: 1px 1px 5px rgba(0,0,0,1); }
        
        .details-text { 
            font-size: 0.85rem; background: rgba(0,0,0,0.5); padding: 12px 15px; border-radius: 8px; margin: 0; 
            white-space: pre-wrap; font-family: 'Consolas', monospace; border-left: 2px solid var(--accent); color: #a1a1aa;
        }

        /* --- SUCHFELD (Aus deinem Code) --- */
        .search-wrapper { position: relative; max-width: 300px; width: 100%; }
        .search-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 240, 255, 0.3);
            border-radius: 30px;
            padding: 10px 15px 10px 40px;
            color: white; font-size: 0.9rem;
            transition: all 0.3s ease;
            width: 100%;
        }
        .search-input:focus {
            background: rgba(0, 240, 255, 0.05); border-color: var(--accent);
            outline: none; box-shadow: 0 0 20px rgba(0, 240, 255, 0.2);
        }
        .search-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); font-size: 0.9rem; color: var(--accent); }

        /* --- TABS (Filter Buttons) --- */
        .tab-btn {
            background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1);
            color: white; padding: 8px 22px; border-radius: 30px; transition: all 0.3s;
            font-weight: 600; letter-spacing: 1px; font-size: 0.8rem;
        }
        .tab-btn:hover { background: rgba(0, 240, 255, 0.1); border-color: var(--accent); color: var(--accent); }
        .tab-btn.active { background: var(--accent); color: #000; border-color: var(--accent); box-shadow: 0 0 15px rgba(0, 240, 255, 0.5); }
        
        .tab-btn.mod-btn:hover { background: rgba(239, 68, 68, 0.1); border-color: #ef4444; color: #ef4444; }
        .tab-btn.mod-btn.active { background: #ef4444; color: #fff; border-color: #ef4444; box-shadow: 0 0 15px rgba(239, 68, 68, 0.5); }

        /* --- PARTIKEL & ANIMATIONEN --- */
        .particles-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; }
        .particle { position: absolute; background: var(--accent); border-radius: 50%; opacity: 0.2; filter: blur(3px); animation: floatUp 15s linear infinite; }
        @keyframes floatUp {
            0% { transform: translateY(110vh) translateX(0); opacity: 0; }
            10% { opacity: 0.4; }
            90% { opacity: 0.4; }
            100% { transform: translateY(-20vh) translateX(100px); opacity: 0; }
        }

        .fa-beat-slow { animation: fa-beat-animation 3s infinite ease-in-out; }
        @keyframes fa-beat-animation { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.2); opacity: 0.5; text-shadow: 0 0 20px var(--accent); } }

        .d-none-search { display: none !important; }
    </style>
</head>
<body>

<div class="particles-container" id="particles"></div>

<div style="position: absolute; top: 20px; right: 20px; z-index: 1000; display: flex; gap: 15px; align-items: center;">
    <a href="/dashboard" class="btn btn-sm shadow-lg d-flex align-items-center" 
       style="background: rgba(0, 240, 255, 0.1); color: var(--accent); border: 1px solid var(--accent); border-radius: 20px; font-weight: bold; padding: 8px 16px; backdrop-filter: blur(10px); transition: all 0.3s ease;" 
       onmouseover="this.style.background='var(--accent)'; this.style.color='#000'; this.style.transform='translateY(-2px)';" 
       onmouseout="this.style.background='rgba(0, 240, 255, 0.1)'; this.style.color='var(--accent)'; this.style.transform='translateY(0)';">
        <i class="fas fa-home me-2"></i> Dashboard
    </a>
    
    <% if (user) { %>
        <div class="d-flex align-items-center bg-dark border border-secondary rounded-pill p-1 pe-3 shadow-sm" style="background: rgba(0,0,0,0.5) !important;">
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                 width="28" height="28" class="rounded-circle me-2 border border-secondary" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
            <span class="fw-bold" style="font-size: 0.85rem;"><%= user.username %></span>
        </div>
    <% } %>
</div>

<div class="container-fluid log-container">
    <div class="text-center mb-5 mt-3">
        <i class="fas fa-eye fa-3x mb-3 fa-beat-slow" style="color: var(--accent);"></i>
        <h1 class="display-5 fw-bold text-white" style="letter-spacing: 4px; text-shadow: 0 0 20px rgba(0, 240, 255, 0.4);">
            BIG BROTHER
        </h1>
        <p class="text-uppercase fw-bold" style="color: var(--accent); letter-spacing: 5px; font-size: 0.9rem;">Server Activity Log</p>
    </div>

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center mb-4 gap-3">
        <div class="search-wrapper">
            <i class="fas fa-search search-icon"></i>
            <input type="text" id="searchInput" class="search-input" placeholder="User, ID, Aktion, Channel...">
        </div>
        
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <button class="tab-btn active filter-btn" data-filter="ALL"><i class="fas fa-globe me-1"></i> Live-Feed</button>
            <button class="tab-btn filter-btn" data-filter="MSG"><i class="fas fa-comment me-1"></i> Chat</button>
            <button class="tab-btn filter-btn" data-filter="VOICE"><i class="fas fa-headset me-1"></i> Voice</button>
            <button class="tab-btn filter-btn" data-filter="STREAM"><i class="fas fa-desktop me-1"></i> Streams</button>
            <button class="tab-btn filter-btn" data-filter="USER"><i class="fas fa-users me-1"></i> Member</button>
            <button class="tab-btn filter-btn mod-btn border-danger text-danger" data-filter="MOD"><i class="fas fa-shield-alt me-1"></i> Moderation</button>
        </div>
    </div>

    <div class="glass-card overflow-hidden">
        <div class="scroll-container">
            <table class="table table-hover align-middle" id="logTable">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 15%"><i class="far fa-clock me-1"></i> Zeit</th>
                        <th style="width: 15%"><i class="fas fa-bolt me-1"></i> Aktion</th>
                        <th style="width: 20%"><i class="fas fa-user-circle me-1"></i> User</th>
                        <th style="width: 40%"><i class="fas fa-terminal me-1"></i> Log Details</th>
                        <th class="pe-4 text-end" style="width: 10%"><i class="fas fa-map-marker-alt me-1"></i> Ort</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(logs.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-5 opacity-50"><i class="fas fa-satellite-dish fa-2x mb-3 d-block"></i>Scanne Signale... Keine Einträge gefunden.</td></tr>
                    <% } %>
                    
                    <% logs.forEach(log => { 
                        let badgeClass = 'bg-sys';
                        let filterType = 'SYS';
                        
                        if (log.action.includes('MSG')) { badgeClass = 'bg-msg'; filterType = 'MSG'; }
                        else if (log.action.includes('STREAM') || log.action.includes('CAM')) { badgeClass = 'bg-stream'; filterType = 'STREAM'; }
                        else if (log.action.includes('VOICE')) { badgeClass = 'bg-voice'; filterType = 'VOICE'; }
                        else if (log.action.includes('ROLE') || log.action.includes('JOIN') || log.action.includes('LEAVE') || log.action.includes('NICKNAME')) { badgeClass = 'bg-user'; filterType = 'USER'; }
                        else if (log.action.includes('BAN') || log.action.includes('TIMEOUT') || log.action.includes('UNBAN')) { badgeClass = 'bg-mod'; filterType = 'MOD'; }
                        
                        let time = new Date(log.timestamp).toLocaleString('de-DE', { timeZone: 'Europe/Berlin', day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
                        let searchString = `${log.action} ${log.username} ${log.userId} ${log.details} ${log.channel}`.toLowerCase();
                    %>
                    <tr class="log-row" data-type="<%= filterType %>" data-search="<%= searchString %>">
                        <td class="ps-4 time-text"><%= time %></td>
                        <td><span class="badge-action <%= badgeClass %>"><%= log.action.replace(/_/g, ' ') %></span></td>
                        <td>
                            <div class="username-bright"><%= log.username %></div>
                            <div class="mt-1" style="font-family: 'Consolas', monospace; font-size: 0.85rem; color: var(--accent-dark); font-weight: 600;">ID: <span style="color: #ffffff;"><%= log.userId %></span></div>
                        </td>
                        <td><div class="details-text"><%= log.details %></div></td>
                        <td class="pe-4 text-end small" style="color: var(--accent); font-weight: 600;"><%= log.channel !== 'System' ? '#' + log.channel : 'SERVER' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        createParticles();

        // Filter Logic
        let currentFilter = 'ALL';
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('.log-row');
        const filterBtns = document.querySelectorAll('.filter-btn');

        function applyFilters() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            rows.forEach(row => {
                const type = row.getAttribute('data-type');
                const text = row.getAttribute('data-search');
                
                const matchesFilter = (currentFilter === 'ALL' || type === currentFilter);
                const matchesSearch = (searchTerm === '' || text.includes(searchTerm));
                
                if (matchesFilter && matchesSearch) {
                    row.classList.remove('d-none-search');
                } else {
                    row.classList.add('d-none-search');
                }
            });
        }

        // Search Input Event
        searchInput.addEventListener('input', applyFilters);

        // Filter Button Events
        filterBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                filterBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.getAttribute('data-filter');
                applyFilters();
            });
        });
    });

    function createParticles() {
        const container = document.getElementById('particles');
        if(!container) return;
        for (let i = 0; i < 20; i++) {
            const p = document.createElement('div');
            p.className = 'particle';
            const size = Math.random() * 4 + 2 + 'px';
            p.style.width = size; p.style.height = size;
            p.style.left = Math.random() * 100 + 'vw';
            p.style.animationDuration = Math.random() * 10 + 10 + 's';
            p.style.animationDelay = Math.random() * 15 + 's';
            container.appendChild(p);
        }
    }
</script>
</body>
</html>
