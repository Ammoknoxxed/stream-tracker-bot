<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Server Logs | Big Brother</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #0b0c10;
            --bg-card: #1f2833;
            --accent: #66fcf1;
            --accent-dark: #45a29e;
            --text-main: #c5c6c7;
            --text-light: #ffffff;
        }

        body { background-color: var(--bg-main); color: var(--text-main); font-family: 'Segoe UI', Roboto, sans-serif; padding-bottom: 50px; }
        
        .log-container { max-width: 1400px; margin: 40px auto; background: var(--bg-card); border-radius: 12px; padding: 25px; box-shadow: 0 15px 35px rgba(0,0,0,0.6); border: 1px solid rgba(102, 252, 241, 0.1); }
        
        /* Suchfeld Styling */
        .search-box { background: rgba(0,0,0,0.3); border: 1px solid var(--accent-dark); color: var(--text-light); }
        .search-box:focus { background: rgba(0,0,0,0.5); border-color: var(--accent); color: var(--text-light); box-shadow: 0 0 10px rgba(102, 252, 241, 0.2); }
        .search-box::placeholder { color: rgba(197, 198, 199, 0.5); }
        
        /* Filter Buttons */
        .filter-btn { background: transparent; border: 1px solid var(--accent-dark); color: var(--accent-dark); margin: 3px; transition: all 0.2s; font-size: 0.85rem; border-radius: 8px; font-weight: 500; }
        .filter-btn:hover, .filter-btn.active { background: var(--accent-dark); color: var(--bg-main); font-weight: bold; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(69, 162, 158, 0.3); }
        
        /* Tabelle */
        .table-wrapper { max-height: 700px; overflow-y: auto; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
        .table { color: var(--text-main); font-size: 0.9rem; margin-bottom: 0; }
        .table thead th { position: sticky; top: 0; background: #171d24; border-bottom: 2px solid var(--accent-dark); color: var(--accent); text-transform: uppercase; letter-spacing: 1px; z-index: 10; font-size: 0.85rem; padding: 15px 10px; }
        .table tbody td { border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; padding: 12px 10px; background: transparent; transition: background 0.2s; }
        .table tbody tr:hover td { background: rgba(255,255,255,0.02); }
        
        /* Badges (Farbcodierung der Aktionen) */
        .badge-action { font-size: 11px; padding: 6px 10px; border-radius: 6px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; min-width: 120px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.2); }
        
        .bg-msg { background-color: #3b82f6; color: white; border: 1px solid #60a5fa; } /* Blau */
        .bg-voice { background-color: #10b981; color: white; border: 1px solid #34d399; } /* Grün */
        .bg-stream { background-color: #fbbf24; color: black; border: 1px solid #fcd34d; } /* Gelb */
        .bg-user { background-color: #a855f7; color: white; border: 1px solid #c084fc; } /* Lila */
        .bg-mod { background-color: #ef4444; color: white; border: 1px solid #f87171; } /* Rot */
        .bg-sys { background-color: #64748b; color: white; border: 1px solid #94a3b8; } /* Grau */

        /* Detail-Feld */
        .details-text { font-size: 0.85rem; background: rgba(0,0,0,0.4); padding: 10px 12px; border-radius: 6px; margin: 0; white-space: pre-wrap; font-family: 'Consolas', monospace; border-left: 3px solid var(--accent-dark); color: #e2e8f0; }
        
        /* Scrollbar für die Tabelle */
        .table-wrapper::-webkit-scrollbar { width: 8px; }
        .table-wrapper::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        .table-wrapper::-webkit-scrollbar-thumb { background: var(--accent-dark); border-radius: 4px; }
        .table-wrapper::-webkit-scrollbar-thumb:hover { background: var(--accent); }
    </style>
</head>
<body>

<div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(0,0,0,0.3); border-bottom: 1px solid rgba(255,255,255,0.05);">
    <div class="fw-bold text-uppercase" style="color: var(--accent); letter-spacing: 1px;">
        <i class="fas fa-shield-alt me-2"></i> Juicer Mod Panel
    </div>
    <div>
        <a href="/dashboard" class="btn btn-outline-info btn-sm me-3 fw-bold"><i class="fas fa-home me-1"></i> Dashboard</a>
        <% if (user) { %>
            <span class="badge bg-dark border border-secondary p-2 shadow-sm" style="font-size: 13px;">
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" width="20" height="20" class="rounded-circle me-2" onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                <%= user.username %>
            </span>
        <% } %>
    </div>
</div>

<div class="log-container">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <h2 class="fw-bold m-0" style="color: var(--accent); text-transform: uppercase; letter-spacing: 2px;">
            <i class="fas fa-eye text-danger"></i> Live Überwachung
        </h2>
        <span class="badge bg-secondary p-2"><i class="fas fa-database me-1"></i> Letzte <%= logs.length %> Einträge</span>
    </div>
    
    <div class="row g-3 mb-4">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text" style="background: rgba(0,0,0,0.3); border: 1px solid var(--accent-dark); color: var(--accent);"><i class="fas fa-search"></i></span>
                <input type="text" id="searchInput" class="form-control search-box" placeholder="Suche User, ID, Aktion, Channel...">
            </div>
        </div>
        
        <div class="col-md-7 d-flex flex-wrap justify-content-md-end align-items-center gap-1">
            <button class="btn filter-btn active" onclick="setFilter('ALL', this)"><i class="fas fa-globe me-1"></i> Alles</button>
            <button class="btn filter-btn" onclick="setFilter('MSG', this)"><i class="fas fa-comment me-1"></i> Chat</button>
            <button class="btn filter-btn" onclick="setFilter('VOICE', this)"><i class="fas fa-headset me-1"></i> Voice</button>
            <button class="btn filter-btn" onclick="setFilter('STREAM', this)"><i class="fas fa-desktop me-1"></i> Streams</button>
            <button class="btn filter-btn" onclick="setFilter('USER', this)"><i class="fas fa-users me-1"></i> Member</button>
            <button class="btn filter-btn text-danger border-danger" onclick="setFilter('MOD', this)"><i class="fas fa-gavel me-1"></i> Mod</button>
        </div>
    </div>

    <div class="table-wrapper shadow-lg">
        <table class="table table-borderless">
            <thead>
                <tr>
                    <th style="width: 15%"><i class="far fa-clock me-1"></i> Zeit</th>
                    <th style="width: 15%"><i class="fas fa-bolt me-1"></i> Event</th>
                    <th style="width: 20%"><i class="fas fa-user me-1"></i> User</th>
                    <th style="width: 40%"><i class="fas fa-info-circle me-1"></i> Details</th>
                    <th style="width: 10%"><i class="fas fa-hashtag me-1"></i> Kanal</th>
                </tr>
            </thead>
            <tbody id="logTableBody">
                <% if(logs.length === 0) { %>
                    <tr><td colspan="5" class="text-center py-5 opacity-50"><i class="fas fa-ghost fa-3x mb-3 d-block"></i>Keine Logs in der Datenbank gefunden.</td></tr>
                <% } %>
                
                <% logs.forEach(log => { 
                    // Kategorisierung für CSS & Filter logic
                    let badgeClass = 'bg-sys';
                    let filterType = 'SYS';
                    
                    if (log.action.includes('MSG')) { badgeClass = 'bg-msg'; filterType = 'MSG'; }
                    else if (log.action.includes('STREAM') || log.action.includes('CAM')) { badgeClass = 'bg-stream'; filterType = 'STREAM'; }
                    else if (log.action.includes('VOICE')) { badgeClass = 'bg-voice'; filterType = 'VOICE'; }
                    else if (log.action.includes('ROLE') || log.action.includes('JOIN') || log.action.includes('LEAVE') || log.action.includes('NICKNAME')) { badgeClass = 'bg-user'; filterType = 'USER'; }
                    else if (log.action.includes('BAN') || log.action.includes('TIMEOUT') || log.action.includes('UNBAN')) { badgeClass = 'bg-mod'; filterType = 'MOD'; }
                    
                    // Zeit Formatierung
                    let time = new Date(log.timestamp).toLocaleString('de-DE', { timeZone: 'Europe/Berlin', day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    
                    // Such-String generieren (Alles, was man suchen können soll, klein geschrieben)
                    let searchString = `${log.action} ${log.username} ${log.userId} ${log.details} ${log.channel}`.toLowerCase();
                %>
                <tr class="log-row" data-type="<%= filterType %>" data-search="<%= searchString %>">
                    <td class="small opacity-75 align-middle"><%= time %></td>
                    <td class="align-middle"><span class="badge-action <%= badgeClass %>"><%= log.action.replace(/_/g, ' ') %></span></td>
                    <td class="align-middle">
                        <span class="fw-bold" style="color: #fff; font-size: 1rem;"><%= log.username %></span><br>
                        <span class="opacity-50" style="font-family: monospace; font-size: 0.8rem;"><i class="fas fa-id-card me-1"></i><%= log.userId %></span>
                    </td>
                    <td class="align-middle"><div class="details-text"><%= log.details %></div></td>
                    <td class="small text-info fw-bold align-middle"><%= log.channel !== 'System' ? '#' + log.channel : 'Server' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    let currentCategory = 'ALL';
    const searchInput = document.getElementById('searchInput');
    const allRows = document.querySelectorAll('.log-row');

    // Funktion wenn ein Filter-Button geklickt wird
    function setFilter(category, btnElement) {
        currentCategory = category;
        
        // Aktive Klasse bei Buttons wechseln
        document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
        btnElement.classList.add('active');
        
        applyFilters();
    }

    // Funktion wenn im Suchfeld getippt wird
    searchInput.addEventListener('input', applyFilters);

    // Haupt-Logik: Kombiniert Suchfeld + Button-Filter
    function applyFilters() {
        const searchText = searchInput.value.toLowerCase().trim();

        allRows.forEach(row => {
            const type = row.getAttribute('data-type');
            const searchableText = row.getAttribute('data-search');

            // Prüfen ob Zeile zur Kategorie passt
            const matchesCategory = (currentCategory === 'ALL' || type === currentCategory);
            // Prüfen ob Zeile zum Suchtext passt
            const matchesSearch = searchText === '' || searchableText.includes(searchText);

            if (matchesCategory && matchesSearch) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
